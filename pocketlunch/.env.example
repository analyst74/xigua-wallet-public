POSTGRES_USER=pocketlunch
POSTGRES_PASSWORD=change_me
# URL-encoded form of POSTGRES_PASSWORD (managed by scripts/start.sh)
POSTGRES_PASSWORD_URLENC=change_me
POSTGRES_DB=pocketlunch

LUNCH_MONEY_API_TOKEN=
LUNCH_MONEY_BASE_URL=https://api.lunchmoney.dev

LM_DEFAULT_LOOKBACK_SECONDS=300
LM_PULL_PAGE_SIZE=100
LM_OUTBOX_BATCH_SIZE=100
LM_MAX_PUSH_ATTEMPTS=8

POCKETLUNCH_SERVICE_BIND_HOST=0.0.0.0
POCKETLUNCH_SERVICE_BIND_PORT=8080

# Optional: set to use API key auth for Codex CLI in codex-runner.
# If empty, run `codex login` inside codex-runner.
OPENAI_API_KEY=
POCKETLUNCH_SERVICE_URL=http://pocketlunch-service:8080
