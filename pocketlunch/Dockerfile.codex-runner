FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git bash ripgrep curl jq \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex

RUN mkdir -p /workspace/context /codex-home \
    && chown -R node:node /workspace /codex-home

USER node
WORKDIR /workspace/context

CMD ["sh", "-lc", "sleep infinity"]
